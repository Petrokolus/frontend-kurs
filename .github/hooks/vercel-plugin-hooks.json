{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node \".github/hooks/scripts/vercel-plugin/hooks/session-start-seen-skills.mjs\""
          },
          {
            "type": "command",
            "command": "node \".github/hooks/scripts/vercel-plugin/hooks/session-start-profiler.mjs\""
          },
          {
            "type": "command",
            "command": "node \".github/hooks/scripts/vercel-plugin/hooks/inject-claude-md.mjs\""
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \".github/hooks/scripts/vercel-plugin/hooks/session-end-cleanup.mjs\""
          }
        ]
      }
    ]
  }
}
