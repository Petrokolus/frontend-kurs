generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Sak {
  id            Int      @id @default(autoincrement())
  tittel        String
  beskrivelse   String
  status        String
  type          String
  saksbehandler String
  opprettet     DateTime @default(now())
}
