generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Spiller {
  id           Int     @id @default(autoincrement())
  navn         String
  avdeling     String
  kull         String
  posisjon     String
  styrke       String?
  svakhet      String?
  rating       Int
  skyggerating Int?
}
